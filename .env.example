# Emotion-Adaptive VR Therapy Platform Configuration
# Get your key at: https://console.groq.com/
GROQ_API_KEY=your_key_here

# LLM Mode: 'local' (default, uses local GGUF model) or 'api' (uses Groq API)
LLM_MODE=local

# Google AI Studio — Gemini Flash TTS (optional)
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here
TTS_BACKEND=gemini
# 0 = always speak, 40+ = only when distressed
TTS_DISTRESS_THRESHOLD=0
GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview

# Hardware Config
SERIAL_PORT=/dev/ttyUSB0
CAMERA_ID=0
AUDIO_CHANNELS=1
WS_PORT=8765
