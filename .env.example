# Nomeda-MSTE Configuration
# Get your key at: https://console.groq.com/
GROQ_API_KEY=your_key_here

# LLM Mode: 'local' (default, uses local GGUF model) or 'api' (uses Groq API)
LLM_MODE=local

# Google AI Studio — Gemini Flash TTS (optional)
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here
TTS_BACKEND=local
# 0 = always speak, 20+ = only when distressed (default 20)
TTS_DISTRESS_THRESHOLD=20

# Hardware Config
CAMERA_ID=0
WS_PORT=8765
